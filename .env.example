# 翻译后端：deeplx（默认）或 openai
TRANSLATE_BACKEND="deeplx"

# --- DeepLX 配置 ---
# 获取方式：https://deeplx.org 或自建服务
# 格式：https://api.deeplx.org/你的token/translate
DEEPLX_URL="https://api.deeplx.org/your-token-here/translate"

# --- OpenAI LLM 配置（备选翻译后端） ---
# 兼容任何 OpenAI 格式的 API（OpenAI、Azure、硅基流动、DeepSeek 等）
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_API_KEY="sk-your-key-here"
# OPENAI_MODEL="gpt-4o-mini"
